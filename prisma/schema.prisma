generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Infrastructure Models ────────────────────────────────────

model BlockchainEvent {
  eventId         BigInt   @id @default(autoincrement()) @map("event_id")
  chainId         Int      @map("chain_id")
  blockNumber     BigInt   @map("block_number")
  blockHash       String   @map("block_hash")
  parentHash      String   @map("parent_hash")
  txHash          String   @map("tx_hash")
  logIndex        Int      @map("log_index")
  contractAddress String   @map("contract_address")
  eventName       String   @map("event_name")
  eventVersion    String   @default("1.0") @map("event_version")
  eventPayload    Json     @map("event_payload")
  isRemoved       Boolean  @default(false) @map("is_removed")
  status          String   @default("pending") // pending / processing / processed / failed / reorg_removed
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([txHash, logIndex])
  @@index([status])
  @@index([blockNumber])
  @@index([contractAddress])
  @@map("blockchain_events")
}

model ProcessedEvent {
  id             Int      @id @default(autoincrement())
  eventId        BigInt   @map("event_id")
  projectionName String   @map("projection_name")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@unique([eventId, projectionName])
  @@map("processed_events")
}

model IndexedBlock {
  blockNumber BigInt   @id @map("block_number")
  blockHash   String   @map("block_hash")
  parentHash  String   @map("parent_hash")
  indexedAt   DateTime @default(now()) @map("indexed_at")
  status      String   @default("synced")

  @@map("indexed_blocks")
}

model ProjectionState {
  projectionName String   @id @map("projection_name")
  lastEventId    BigInt   @map("last_event_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("projection_state")
}

model DeadLetterEvent {
  id             Int      @id @default(autoincrement())
  eventId        BigInt   @map("event_id")
  projectionName String   @map("projection_name")
  errorMessage   String   @db.Text @map("error_message")
  retryCount     Int      @default(0) @map("retry_count")
  status         String   @default("pending") // pending / retrying / resolved / permanent_failure
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("dead_letter_events")
}

model SyncMetric {
  id          Int      @id @default(autoincrement())
  metricName  String   @unique @map("metric_name")
  metricValue String   @map("metric_value")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sync_metrics")
}

// ─── Read Model Models ────────────────────────────────────────

model PortfolioPosition {
  id                Int      @id @default(autoincrement())
  walletAddress     String   @map("wallet_address")
  vaultAddress      String   @map("vault_address")
  shares            Decimal  @db.Decimal(30, 18) @map("shares")
  lastUpdatedBlock  BigInt   @map("last_updated_block")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([walletAddress, vaultAddress])
  @@map("portfolio_positions")
}

model Vault {
  id           Int      @id @default(autoincrement())
  vaultAddress String   @unique @map("vault_address")
  assetAddress String   @map("asset_address")
  name         String   @map("name")
  symbol       String   @map("symbol")
  category     String   @map("category")
  vaultType    String   @map("vault_type") // SYNC / ASYNC
  creator      String   @map("creator")
  tvl          Decimal  @default(0) @db.Decimal(30, 18) @map("tvl")
  totalShares  Decimal  @default(0) @db.Decimal(30, 18) @map("total_shares")
  active       Boolean  @default(true) @map("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("vaults")
}

model FeeRecord {
  id           Int      @id @default(autoincrement())
  vaultAddress String   @map("vault_address")
  feeType      String   @map("fee_type") // mgmt / perf / entry / exit / trading
  amount       Decimal  @db.Decimal(30, 18) @map("amount")
  recipient    String?  @map("recipient")
  txHash       String   @map("tx_hash")
  blockNumber  BigInt   @map("block_number")
  timestamp    DateTime @map("timestamp")

  @@map("fee_records")
}

model Settlement {
  id           Int       @id @default(autoincrement())
  vaultAddress String    @map("vault_address")
  requestId    String    @map("request_id")
  investor     String    @map("investor")
  shares       Decimal   @db.Decimal(30, 18) @map("shares")
  assets       Decimal   @db.Decimal(30, 18) @map("assets")
  status       String    @map("status") // pending / processed / claimed / cancelled / completed / failed
  failReason   String?   @db.Text @map("fail_reason")
  requestTime  DateTime  @map("request_time")
  settleTime   DateTime? @map("settle_time")
  txHash       String    @map("tx_hash")
  blockNumber  BigInt    @map("block_number")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([vaultAddress, requestId])
  @@map("settlements")
}

model NavSubmission {
  id            Int      @id @default(autoincrement())
  assetId       String   @map("asset_id")
  navValue      Decimal  @db.Decimal(30, 18) @map("nav_value")
  method        String   @map("method")
  submitter     String   @map("submitter")
  status        String   @map("status") // draft / verified / submitted / published / disputed
  valuationDate DateTime @map("valuation_date")
  submittedAt   DateTime @map("submitted_at")
  txHash        String   @map("tx_hash")
  blockNumber   BigInt   @map("block_number")

  @@map("nav_submissions")
}

model TokenHolder {
  id            Int      @id @default(autoincrement())
  tokenAddress  String   @map("token_address")
  holderAddress String   @map("holder_address")
  balance       Decimal  @db.Decimal(30, 18) @map("balance")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tokenAddress, holderAddress])
  @@map("token_holders")
}

model ProtocolMetric {
  id           Int      @id @default(autoincrement())
  tvl          Decimal  @default(0) @db.Decimal(30, 18) @map("tvl")
  totalFees    Decimal  @default(0) @db.Decimal(30, 18) @map("total_fees")
  activeVaults Int      @default(0) @map("active_vaults")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("protocol_metrics")
}

model Block {
  blockNumber BigInt   @id @map("block_number")
  blockHash   String   @map("block_hash")
  parentHash  String   @map("parent_hash")
  timestamp   DateTime @map("timestamp")
  gasUsed     BigInt   @map("gas_used")
  txCount     Int      @map("tx_count")

  @@map("blocks")
}

model Transaction {
  txHash          String   @id @map("tx_hash")
  blockNumber     BigInt   @map("block_number")
  fromAddress     String   @map("from_address")
  toAddress       String?  @map("to_address")
  contractAddress String?  @map("contract_address")
  method          String?  @map("method")
  status          String   @map("status") // SUCCESS / REVERTED
  gasUsed         BigInt   @map("gas_used")
  gasLimit        BigInt?  @map("gas_limit")
  value           String   @map("value") // Wei stored as String
  gasPrice        BigInt?  @map("gas_price")
  transactionFee  String?  @db.VarChar(255) @map("transaction_fee")
  tokenName       String?  @map("token_name")
  tokenSymbol     String?  @map("token_symbol")
  tokenAmount     String?  @map("token_amount")
  timestamp       DateTime @map("timestamp")

  @@index([blockNumber])
  @@index([fromAddress])
  @@index([toAddress])
  @@map("transactions")
}

model Log {
  id              Int      @id @default(autoincrement())
  txHash          String   @map("tx_hash")
  logIndex        Int      @map("log_index")
  address         String   @map("address")
  topics          String   @db.Text @map("topics") // JSON array of topics
  data            String?  @db.LongText @map("data")
  blockNumber     BigInt   @map("block_number")

  @@unique([txHash, logIndex])
  @@map("logs")
}

model SyncStatus {
  id                 Int      @id @default(autoincrement())
  chainId            Int      @unique @map("chain_id")
  lastSyncedBlock    BigInt   @map("last_synced_block")
  latestBlock        BigInt   @map("latest_block")
  progressPercentage Decimal  @db.Decimal(5, 2) @map("progress_percentage")
  status             String   @map("status") // idle / syncing / completed / error
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("sync_status")
}

model FailedBlock {
  blockNumber BigInt   @id @map("block_number")
  error       String   @db.Text @map("error")
  retryCount  Int      @default(0) @map("retry_count")
  timestamp   DateTime @default(now()) @map("timestamp")

  @@map("failed_blocks")
}

// ─── Layer 1: Identity & Compliance Models ─────────────────────

model SbtIdentity {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @unique @map("wallet_address")
  did             String   @map("did")
  countryCode     Int      @map("country_code")
  investorType    String   @map("investor_type") // RETAIL / ACCREDITED / INSTITUTIONAL
  isVerified      Boolean  @default(true) @map("is_verified")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("sbt_identities")
}

model WalletComplianceState {
  id              Int      @id @default(autoincrement())
  walletAddress   String   @map("wallet_address")
  tokenAddress    String   @map("token_address")
  isFrozen        Boolean  @default(false) @map("is_frozen")
  isRestricted    Boolean  @default(false) @map("is_restricted")
  restrictionCode Int      @default(0) @map("restriction_code")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([walletAddress, tokenAddress])
  @@map("wallet_compliance_states")
}

// ─── Layer 2: Carbon Metadata & Batch Models ──────────────────

model CarbonAssetMetadata {
  id                        Int      @id @default(autoincrement())
  assetId                   String   @unique @map("asset_id")
  contractAddress           String   @map("contract_address")
  projectId                 String   @map("project_id")
  methodology               String   @map("methodology")
  projectType               String   @map("project_type")
  country                   String   @map("country")
  standard                  String   @map("standard")
  serialNumberRange         String   @map("serial_number_range")
  verificationReportHash    String   @map("verification_report_hash")
  pddHash                   String   @map("pdd_hash")
  monitoringReportHash      String   @map("monitoring_report_hash")
  issuanceCertificateHash   String   @map("issuance_certificate_hash")
  immobilizationProofHash   String   @map("immobilization_proof_hash")
  icvcmApproved             Boolean  @default(true) @map("icvcm_approved")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@map("carbon_asset_metadata")
}

model CarbonBatch {
  id               Int      @id @default(autoincrement())
  batchId          String   @unique @map("batch_id")
  assetId          String   @map("asset_id")
  vintageYear      Int      @map("vintage_year")
  totalCredits     Decimal  @db.Decimal(30, 18) @map("total_credits")
  availableCredits Decimal  @db.Decimal(30, 18) @map("available_credits")
  retiredCredits   Decimal  @default(0) @db.Decimal(30, 18) @map("retired_credits")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("carbon_batches")
}

// ─── Layer 3: Nav, Vault & Fee Models ─────────────────────────

model NavAttestation {
  id              Int      @id @default(autoincrement())
  assetId         String   @map("asset_id")
  tokenAddress    String   @map("token_address")
  navValueUsd     Decimal  @db.Decimal(30, 18) @map("nav_value_usd")
  method          String   @map("method")
  verifierAddress String   @map("verifier_address")
  valuationDate   DateTime @map("valuation_date")
  txHash          String   @map("tx_hash")
  blockNumber     BigInt   @map("block_number")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("nav_attestations")
}

model FeeAccrualLog {
  id              Int      @id @default(autoincrement())
  vaultAddress    String   @map("vault_address")
  feeType         String   @map("fee_type") // MANAGEMENT / PERFORMANCE / ENTRY / EXIT
  feeBps          Int      @map("fee_bps")
  feeAmountUsd    Decimal  @db.Decimal(30, 18) @map("fee_amount_usd")
  recipient       String   @map("recipient")
  hwmCheckpoint   Decimal? @db.Decimal(30, 18) @map("hwm_checkpoint")
  txHash          String   @map("tx_hash")
  blockNumber     BigInt   @map("block_number")
  timestamp       DateTime @map("timestamp")

  @@map("fee_accrual_logs")
}

// ─── Layer 4: BOR, P2P & Retirement Models ────────────────────

model BeneficialOwnerRecord {
  id                Int      @id @default(autoincrement())
  tokenAddress      String   @map("token_address")
  investorAddress   String   @map("investor_address")
  investorHandle    String?  @map("investor_handle")
  balance           Decimal  @db.Decimal(30, 18) @map("balance")
  ownershipPercent  Decimal  @db.Decimal(10, 4) @map("ownership_percent")
  entryNav          Decimal  @db.Decimal(30, 18) @map("entry_nav")
  totalValueUsd     Decimal  @db.Decimal(30, 18) @map("total_value_usd")
  lastUpdatedBlock  BigInt   @map("last_updated_block")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([tokenAddress, investorAddress])
  @@map("beneficial_owner_records")
}

model P2pSettlementLog {
  id              Int      @id @default(autoincrement())
  swapId          String   @map("swap_id")
  tokenAddress    String   @map("token_address")
  senderAddress   String   @map("sender_address")
  senderHandle    String?  @map("sender_handle")
  receiverAddress String   @map("receiver_address")
  receiverHandle  String?  @map("receiver_handle")
  amount          Decimal  @db.Decimal(30, 18) @map("amount")
  priceUsd        Decimal  @db.Decimal(30, 18) @map("price_usd")
  settlementType  String   @map("settlement_type") // P2P_DVP / PRIMARY_MINT
  txHash          String   @map("tx_hash")
  blockNumber     BigInt   @map("block_number")
  timestamp       DateTime @map("timestamp")

  @@map("p2p_settlement_logs")
}

model CarbonRetirementRecord {
  id               Int      @id @default(autoincrement())
  retirementId     String   @unique @map("retirement_id")
  retireeAddress   String   @map("retiree_address")
  retireeHandle    String?  @map("retiree_handle")
  amount           Decimal  @db.Decimal(30, 18) @map("amount")
  beneficiaryName  String   @map("beneficiary_name")
  retirementReason String   @map("retirement_reason")
  certificateCid   String?  @map("certificate_cid")
  status           String   @map("status") // SUCCESS / PENDING_RETRY / ESCALATED
  txHash           String   @map("tx_hash")
  blockNumber      BigInt   @map("block_number")
  timestamp        DateTime @map("timestamp")

  @@map("carbon_retirement_records")
}

model AssetLifecycleExit {
  id                   Int      @id @default(autoincrement())
  exitId               String   @unique @map("exit_id")
  tokenAddress         String   @map("token_address")
  vaultAddress         String   @map("vault_address")
  liquidationUsdcPool  Decimal  @db.Decimal(30, 18) @map("liquidation_usdc_pool")
  totalSharesLocked    Decimal  @db.Decimal(30, 18) @map("total_shares_locked")
  payoutPerShare       Decimal  @db.Decimal(30, 18) @map("payout_per_share")
  txHash               String   @map("tx_hash")
  blockNumber          BigInt   @map("block_number")
  timestamp            DateTime @map("timestamp")

  @@map("asset_lifecycle_exits")
}

// ─── Real Estate & Fine Art Plugin Metadata Models ───────────

model RealEstateMetadata {
  id                Int      @id @default(autoincrement())
  assetId           String   @unique @map("asset_id")
  contractAddress   String   @map("contract_address")
  propertyName      String   @map("property_name")
  propertyType      String   @map("property_type") // RESIDENTIAL / COMMERCIAL / INDUSTRIAL / LAND
  squareFootage     Decimal  @db.Decimal(15, 2) @map("square_footage")
  appraisalValueUsd Decimal  @db.Decimal(30, 18) @map("appraisal_value_usd")
  occupancyRateBps  Int      @default(10000) @map("occupancy_rate_bps")
  zoningClass       String?  @map("zoning_class")
  locationAddress   String   @map("location_address")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("real_estate_metadata")
}

model FineArtMetadata {
  id                   Int      @id @default(autoincrement())
  assetId              String   @unique @map("asset_id")
  contractAddress      String   @map("contract_address")
  title                String   @map("title")
  artist               String   @map("artist")
  medium               String   @map("medium")
  creationYear         Int      @map("creation_year")
  appraisalValueUsd    Decimal  @db.Decimal(30, 18) @map("appraisal_value_usd")
  provenanceIpfsHash   String?  @map("provenance_ipfs_hash")
  authCertificateHash  String   @map("auth_certificate_hash")
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("fine_art_metadata")
}

// ─── Off-Chain Document Registry (DMS v4) Model ─────────────

model DmsDocument {
  id                Int      @id @default(autoincrement())
  documentId        String   @unique @map("document_id")
  assetId           String   @map("asset_id")
  documentType      String   @map("document_type") // PROSPECTUS / APPRAISAL / PDD / VERIFICATION / TITLE_DEED
  sha256Hash        String   @map("sha256_hash")
  fileUri           String   @map("file_uri")
  isVerified        Boolean  @default(true) @map("is_verified")
  expiryDate        DateTime? @map("expiry_date")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("dms_documents")
}

// ─── Financial Yield & Physical Redemption Models ─────────────

model YieldDistribution {
  id                 Int      @id @default(autoincrement())
  distributionId     String   @unique @map("distribution_id")
  vaultAddress       String   @map("vault_address")
  totalYieldUsd      Decimal  @db.Decimal(30, 18) @map("total_yield_usd")
  yieldPerShareUsd   Decimal  @db.Decimal(30, 18) @map("yield_per_share_usd")
  snapshotBlock      BigInt   @map("snapshot_block")
  txHash             String   @map("tx_hash")
  timestamp          DateTime @default(now()) @map("timestamp")

  @@map("yield_distributions")
}

model YieldClaim {
  id              Int      @id @default(autoincrement())
  claimId         String   @unique @map("claim_id")
  distributionId  String   @map("distribution_id")
  investorAddress String   @map("investor_address")
  amountClaimed   Decimal  @db.Decimal(30, 18) @map("amount_claimed")
  txHash          String   @map("tx_hash")
  timestamp       DateTime @default(now()) @map("timestamp")

  @@map("yield_claims")
}

model PhysicalRedemption {
  id               Int      @id @default(autoincrement())
  redemptionId     String   @unique @map("redemption_id")
  tokenAddress     String   @map("token_address")
  investorAddress  String   @map("investor_address")
  amountTokens     Decimal  @db.Decimal(30, 18) @map("amount_tokens")
  status           String   @map("status") // REQUESTED / IN_ESCROW / SHIPPED / PHYSICAL_SETTLED / REJECTED
  trackingRef      String?  @map("tracking_ref")
  txHash           String   @map("tx_hash")
  timestamp        DateTime @default(now()) @map("timestamp")

  @@map("physical_redemptions")
}

// ─── Compliance Travel Rule & Governance Models ──────────────

model TravelRuleVaspLog {
  id                 Int      @id @default(autoincrement())
  txHash             String   @unique @map("tx_hash")
  originatorAddress  String   @map("originator_address")
  beneficiaryAddress String   @map("beneficiary_address")
  originatorVasp     String   @map("originator_vasp")
  beneficiaryVasp    String   @map("beneficiary_vasp")
  amountUsd          Decimal  @db.Decimal(30, 18) @map("amount_usd")
  status             String   @map("status") // PASSED / BLOCKED / FLAGGED
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("travel_rule_vasp_logs")
}

model InvestorRightsLog {
  id              Int      @id @default(autoincrement())
  tokenAddress    String   @map("token_address")
  investorAddress String   @map("investor_address")
  votingPower     Decimal  @db.Decimal(30, 18) @map("voting_power")
  dividendRight   Decimal  @db.Decimal(10, 4) @map("dividend_right")
  hasInspection   Boolean  @default(true) @map("has_inspection")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tokenAddress, investorAddress])
  @@map("investor_rights_logs")
}
